# DormFix 环境变量示例（新手版）
# 用法：
# 1) 复制：cp .env.example .env
# 2) 至少填写 LLM_API_KEY
# 3) 其他项可先保持默认，项目也能跑

# =========================
# [可选] Django 基础配置（本地开发可不改）
# =========================
# 生产环境建议改为你自己的随机密钥
DJANGO_SECRET_KEY=replace-with-your-secret-key
# 本地开发建议 True，线上改 False
DJANGO_DEBUG=True
# 允许访问的域名/IP，多个用逗号分隔
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =========================
# [可选] 数据库配置
# 说明：DB_PASSWORD 留空 => 使用 SQLite（最省事）
#      DB_PASSWORD 非空 => 切换到 MySQL
# =========================
DB_PASSWORD=
DB_NAME=DormFix
DB_USER=root
DB_HOST=localhost
DB_PORT=3306

# =========================
# [必填] 知识问答大模型配置
# =========================
# 你的大模型平台 API Key（必须填写，否则知识问答不可用）
LLM_API_KEY=your_api_key_here
# OpenAI 兼容接口地址
# - OpenAI: https://api.openai.com/v1
# - 阿里 MaaS(OpenAI兼容): https://<workspace>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.openai.com/v1
# 模型名称，可按平台支持情况调整
# - OpenAI 示例: gpt-4o-mini
# - 阿里 MaaS 示例: qwen-plus
LLM_MODEL=gpt-4o-mini
# 请求超时时间（秒）
LLM_TIMEOUT_SECONDS=30
